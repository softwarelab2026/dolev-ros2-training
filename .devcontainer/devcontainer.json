{
  "name": "ROS2 Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
   "runArgs": [
    "-e", "DISPLAY=$DISPLAY",
    "-v", "/tmp/.X11-unix:/tmp/.X11-unix"
  ],
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postStartCommand": "./.devcontainer/ros2_commands.sh"
}