{
  "name": "ROS2 Dev",
  "image": "osrf/ros:humble-desktop",
  "runArgs": [
    "-e", "DISPLAY=host.docker.internal:0"
  ],
  "mounts": [
    "source=${env:HOME}/.ssh/id_ed25519,target=/root/.ssh/id_ed25519,type=bind,consistency=cached",
    "source=${env:HOME}/.ssh/id_ed25519.pub,target=/root/.ssh/id_ed25519.pub,type=bind,consistency=cached",
    "source=${env:HOME}/.ssh/known_hosts,target=/root/.ssh/known_hosts,type=bind,consistency=cached"
  ],
  "postCreateCommand": "./post_installations.sh",
  "remoteUser": "root"
}



