{
  "name": "ROS2 Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
   "runArgs": [
    "-e", "DISPLAY=$DISPLAY",
    "-v", "/tmp/.X11-unix:/tmp/.X11-unix"
  ],
   "mounts": [
    "source=${env:USERPROFILE}\\.ssh\\id_ed25519,target=/root/.ssh/id_ed25519,type=bind,consistency=cached",
    "source=${env:USERPROFILE}\\.ssh\\id_ed25519.pub,target=/root/.ssh/id_ed25519.pub,type=bind,consistency=cached",
    "source=${env:USERPROFILE}\\.ssh\\known_hosts,target=/root/.ssh/known_hosts,type=bind,consistency=cached"
], 
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postStartCommand": "./.devcontainer/ros2_commands.sh"
}