{
  "name": "ROS2 Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "-e", "DISPLAY=host.docker.internal:0"
  ],
  "mounts": [
    "source=${env:HOME}/.ssh/id_ed25519,target=/root/.ssh/id_ed25519,type=bind",
    "source=${env:HOME}/.ssh/id_ed25519.pub,target=/root/.ssh/id_ed25519.pub,type=bind",
    "source=${env:HOME}/.ssh/known_hosts,target=/root/.ssh/known_hosts,type=bind"
  ],

  "remoteUser": "root"
}